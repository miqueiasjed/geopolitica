# ══════════════════════════════════════════════════════════════════
#  Geopolítica para Investidores — .env de exemplo
#  Copie para .env e preencha os valores marcados com (OBRIGATÓRIO)
# ══════════════════════════════════════════════════════════════════

# ── Aplicação ─────────────────────────────────────────────────────
APP_NAME="Geopolitica para Investidores"
APP_ENV=production
APP_KEY=                          # (OBRIGATÓRIO) Gere com: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.seudominio.com.br
APP_DOMAIN=seudominio.com.br      # Domínio raiz (sem subdomínio)

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logs ──────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # Em produção use error; em dev use debug

# ── Banco de dados ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=geopolitica           # (OBRIGATÓRIO) Nome do banco MySQL
DB_USERNAME=geopolitica           # (OBRIGATÓRIO)
DB_PASSWORD=                      # (OBRIGATÓRIO)

# ── Cache, Session e Filas (Redis) ────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.seudominio.com.br # Com ponto no início para subdomínios B2B
SESSION_STORE=redis
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=gpi_

REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null               # Defina se o Redis exigir autenticação
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default

# ── E-mail (Resend) ───────────────────────────────────────────────
# Documentação: https://resend.com/docs
MAIL_MAILER=resend
MAIL_SCHEME=https
MAIL_HOST=api.resend.com
MAIL_PORT=443
MAIL_USERNAME=resend
MAIL_PASSWORD=                    # Mesmo valor de RESEND_API_KEY abaixo
MAIL_FROM_ADDRESS="no-reply@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=                       # (OBRIGATÓRIO) Chave do Resend — ex: re_xxxxxxx

RESEND_API_KEY=                   # (OBRIGATÓRIO) Mesma chave acima (usada pelos serviços internos)
RESEND_FROM_EMAIL=alertas@seudominio.com.br

# ── IA — Provedor ─────────────────────────────────────────────────
AI_PROVIDER=claude                # Provedor ativo: claude | openai

# ── IA / Anthropic Claude ─────────────────────────────────────────
# Documentação: https://console.anthropic.com
CLAUDE_API_KEY=                   # Chave Claude — ex: sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6    # Modelo padrão para análises
CLAUDE_MAX_TOKENS=1024            # Máximo de tokens por resposta

# ── IA / OpenAI ───────────────────────────────────────────────────
# Documentação: https://platform.openai.com
OPENAI_API_KEY=                   # Chave OpenAI — ex: sk-...
OPENAI_MODEL=gpt-4o               # Modelo padrão (ex: gpt-4o, gpt-4o-mini)
OPENAI_MAX_TOKENS=1024            # Máximo de tokens por resposta

# ── Pagamentos / Hotmart ──────────────────────────────────────────
# Configure o webhook em: Hotmart > Ferramentas > Webhooks
# URL: https://api.seudominio.com.br/api/webhook/hotmart
HOTMART_WEBHOOK_TOKEN=            # (OBRIGATÓRIO) Token secreto definido no painel Hotmart
HOTMART_PRODUCT_ELECTIONS=        # ID do produto Monitor Eleitoral na Hotmart
HOTMART_PRODUCT_WAR=              # ID do produto Monitor de Guerra na Hotmart

# ── Pagamentos / Lastlink ─────────────────────────────────────────
# Configure o webhook em: Lastlink > Configurações > Webhooks
# URL: https://api.seudominio.com.br/api/webhook/lastlink
LASTLINK_WEBHOOK_SECRET=          # (OBRIGATÓRIO) Token secreto definido no painel Lastlink
LASTLINK_PRODUCT_ELECTIONS=       # ID do produto Monitor Eleitoral na Lastlink
LASTLINK_PRODUCT_WAR=             # ID do produto Monitor de Guerra na Lastlink

# ── Segurança ─────────────────────────────────────────────────────
# Segredo para autenticar chamadas de cron job externas (cPanel, cron.job, etc.)
# Gere com: openssl rand -hex 32
CRON_SECRET=                      # (OBRIGATÓRIO em produção)

# ── Frontend / CORS ───────────────────────────────────────────────
FRONTEND_URL=https://seudominio.com.br
SANCTUM_STATEFUL_DOMAINS=seudominio.com.br,www.seudominio.com.br

# ── Feed de Tensões ───────────────────────────────────────────────
FEED_REFRESH_INTERVAL=30          # Intervalo de atualização em minutos
FEED_MAX_ITEMS=50                 # Máximo de itens retornados por request

# ── Alertas Preditivos ────────────────────────────────────────────
ALERTA_THRESHOLD_CRITICAL=10      # Score mínimo para alerta crítico (0–10)
ALERTA_THRESHOLD_HIGH=7           # Score mínimo para alerta alto (0–10)
ALERTA_THRESHOLD_MEDIUM=4         # Score mínimo para alerta médio (0–10)
CONVERGENCIA_JANELA_HORAS=72      # Janela de análise de convergência de sinais

# ── Limites do Chat ───────────────────────────────────────────────
LIMITE_CHAT_ESSENCIAL=5           # Perguntas/dia no plano Essencial
LIMITE_CHAT_PRO=20                # Perguntas/dia no plano Pro
# Plano Reservado e Admin: ilimitado

# ── Permissões (Spatie) ───────────────────────────────────────────
PERMISSION_CACHE_STORE=default

# ── Admin Inicial ─────────────────────────────────────────────────
# Usado pelo AdminSeeder para criar o primeiro administrador
ADMIN_EMAIL=admin@seudominio.com.br  # (OBRIGATÓRIO)
ADMIN_PASSWORD=troque-esta-senha     # (OBRIGATÓRIO) Altere imediatamente após deploy

# ── Build do Frontend ─────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
