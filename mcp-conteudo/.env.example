# URL base da API Laravel (sem barra final). Padrao: https://mygip.com.br/api
# Para apontar para um backend local, use http://localhost:8000/api
API_BASE_URL=https://mygip.com.br/api

# Opcao A (recomendada): token Sanctum de um usuario admin.
# Gere com: php artisan conteudo:mcp-token seu-email@admin.com
ADMIN_TOKEN=

# Opcao B: login automatico com e-mail e senha de um admin.
# Usado apenas quando ADMIN_TOKEN estiver vazio.
ADMIN_EMAIL=
ADMIN_PASSWORD=
